{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/install-plugin.ps1"
    }
  ],
  "headers": [
    {
      "source": "/install-plugin.ps1",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Content-Disposition",
          "value": "inline; filename=\"install-plugin.ps1\""
        }
      ]
    }
  ]
}
